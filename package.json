{
  "name": "ai-automation-platform",
  "version": "1.0.0",
  "description": "AI Automation Platform with 8 specialized agents using 100% free services",
  "main": "index.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "type-check": "tsc --noEmit",
    "setup:check": "node scripts/check-dependencies.js",
    "setup:keys": "node scripts/generate-keys.js",
    "setup:db": "node scripts/setup-database.js",
    "setup": "chmod +x scripts/setup-free-services.sh && ./scripts/setup-free-services.sh",
    "docker:up": "docker-compose -f docker-compose.free.yml up -d",
    "docker:down": "docker-compose -f docker-compose.free.yml down",
    "docker:logs": "docker-compose -f docker-compose.free.yml logs -f"
  },
  "dependencies": {
    "next": "^14.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "@supabase/supabase-js": "^2.38.0",
    "next-auth": "^4.24.0",
    "@next-auth/supabase-adapter": "^1.0.0",
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "tailwindcss": "^3.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "lucide-react": "^0.294.0",
    "clsx": "^2.0.0",
    "framer-motion": "^10.16.0",
    "dotenv": "^16.3.0",
    "joi": "^17.11.0",
    "node-fetch": "^3.3.0"
  },
  "devDependencies": {
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.0.0",
    "jest": "^29.0.0",
    "@testing-library/react": "^13.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "prisma": "^5.0.0",
    "@types/jest": "^29.0.0"
  },
  "peerDependencies": {
    "@google/generative-ai": "^0.1.0",
    "groq-sdk": "^0.3.0",
    "together-ai": "^0.2.0"
  },
  "peerDependenciesMeta": {
    "@google/generative-ai": {
      "optional": true
    },
    "groq-sdk": {
      "optional": true
    },
    "together-ai": {
      "optional": true
    }
  },
  "keywords": [
    "ai",
    "automation",
    "platform",
    "free",
    "next.js",
    "supabase",
    "huggingface",
    "agents",
    "workflow"
  ],
  "author": "AI Automation Platform",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mrsonly86/ai-automation-platform.git"
  },
  "bugs": {
    "url": "https://github.com/mrsonly86/ai-automation-platform/issues"
  },
  "homepage": "https://github.com/mrsonly86/ai-automation-platform#readme",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}