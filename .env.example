// Simple environment file for demo
PORT=3000
NODE_ENV=development

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# InfluxDB Configuration
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=demo-token
INFLUXDB_ORG=ai-automation
INFLUXDB_BUCKET=predictions

# Vietnam E-Invoice Configuration
VN_TAX_API_URL=https://tracuuhoadon.gdt.gov.vn
VN_COMPANY_TAX_CODE=0123456789

# Azure Speech Services
AZURE_SPEECH_KEY=demo-key
AZURE_SPEECH_REGION=southeastasia

# Security
JWT_SECRET=ai-automation-platform-secret-demo
ENCRYPTION_KEY=demo-encryption-key-32-characters