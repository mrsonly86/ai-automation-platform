NODE_ENV=development
PORT=3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/ai-automation-platform

# Vietnam Tax Authority
VN_TAX_AUTHORITY_URL=https://api.gdt.gov.vn
VN_TAX_API_KEY=your_tax_api_key_here
VN_COMPANY_TAX_CODE=1234567890

# Vietnam E-Invoice
VN_INVOICE_TEMPLATE=default
VN_VAT_RATE=0.1
VN_CERT_PATH=
VN_CERT_PASSWORD=

# Vietnamese Voice Assistant
VOICE_SR_PROVIDER=web-speech-api
VOICE_TTS_PROVIDER=web-speech-api
VOICE_TTS_SPEED=1.0
VOICE_NLP_MODEL=phobert
VOICE_NLP_THRESHOLD=0.8

# Security
JWT_SECRET=your_jwt_secret_here

# Logging
LOG_LEVEL=info