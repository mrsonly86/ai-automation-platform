# Environment Variables Template for Free Setup

# =============================================================================
# AI PROVIDERS (FREE TIERS) - Choose at least one
# =============================================================================

# Hugging Face (RECOMMENDED - Unlimited free inference)
# Get your token at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_your_token_here

# Google AI Studio (Gemini API - Free quota monthly)
# Get API key at: https://makersuite.google.com/app/apikey
GOOGLE_AI_API_KEY=your_gemini_api_key_here

# Groq (Fast inference - Free tier)
# Sign up at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Together AI (Free tier)
# Get API key at: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=your_together_api_key_here

# =============================================================================
# DATABASE OPTIONS (FREE TIERS) - Choose one
# =============================================================================

# Option 1: Supabase (RECOMMENDED - 500MB PostgreSQL + Auth + Real-time)
# Create project at: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Option 2: Neon.tech (3GB PostgreSQL serverless)
# Create database at: https://console.neon.tech
# NEON_DATABASE_URL=postgresql://user:password@host/dbname

# Option 3: PlanetScale (5GB MySQL)
# Create database at: https://planetscale.com
# PLANETSCALE_DATABASE_URL=mysql://user:password@host:port/dbname

# Option 4: MongoDB Atlas (512MB free cluster)
# Create cluster at: https://cloud.mongodb.com
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

# NextAuth.js secret (generate with: node scripts/generate-keys.js)
NEXTAUTH_SECRET=your_generated_secret_key_here

# App URL (update for production)
NEXTAUTH_URL=http://localhost:3000

# JWT Secret for additional security
JWT_SECRET=your_jwt_secret_here

# =============================================================================
# OPTIONAL FREE SERVICES
# =============================================================================

# Redis (Free tier from Upstash - 10,000 requests/day)
# Create database at: https://console.upstash.com
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token

# Email (Free tier from Resend - 3,000 emails/month)
# Get API key at: https://resend.com/api-keys
# RESEND_API_KEY=re_your_api_key

# File Storage (Free tier from Cloudinary - 25 credits/month)
# Get credentials at: https://cloudinary.com/console
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Environment
NODE_ENV=development

# Debug modes
DEBUG_AI_PROVIDERS=false
DEBUG_DATABASE=false
DEBUG_CACHE=false

# Rate limiting (requests per minute)
RATE_LIMIT_RPM=60

# Cache TTL (Time To Live in seconds)
CACHE_TTL=3600

# =============================================================================
# PRODUCTION DEPLOYMENT SETTINGS
# =============================================================================

# Vercel Analytics (Free)
# NEXT_PUBLIC_VERCEL_ANALYTICS=true

# Sentry Error Tracking (Free tier - 5,000 errors/month)
# Create project at: https://sentry.io
# SENTRY_DSN=https://your-dsn@sentry.io/project-id

# =============================================================================
# AI PROVIDER FALLBACK CONFIGURATION
# =============================================================================

# Primary AI provider (will be used first)
PRIMARY_AI_PROVIDER=huggingface

# Fallback providers (comma-separated, in order of preference)
FALLBACK_AI_PROVIDERS=groq,google,together

# Enable automatic fallback when quota exceeded
AUTO_FALLBACK_ENABLED=true

# =============================================================================
# FEATURE FLAGS (FREE TIER OPTIMIZATIONS)
# =============================================================================

# Enable caching to reduce API calls
ENABLE_CACHING=true

# Enable request deduplication
ENABLE_DEDUPLICATION=true

# Enable response compression
ENABLE_COMPRESSION=true

# Maximum concurrent requests per user
MAX_CONCURRENT_REQUESTS=3

# Enable usage analytics
ENABLE_USAGE_TRACKING=true