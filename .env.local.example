# Local Development Environment Template

# =============================================================================
# LOCAL DEVELOPMENT SETTINGS
# =============================================================================

# AI Provider for local development (use free tier)
HUGGINGFACE_API_KEY=hf_your_development_token

# Local database (using Docker Compose)
DATABASE_URL=postgresql://ai_platform:ai_platform_password@localhost:5432/ai_platform_dev

# Local Redis (using Docker Compose)
REDIS_URL=redis://localhost:6379

# NextAuth settings for local development
NEXTAUTH_SECRET=your-local-dev-secret-key-minimum-32-characters
NEXTAUTH_URL=http://localhost:3000

# =============================================================================
# LOCAL DOCKER SERVICES
# =============================================================================

# PostgreSQL (from docker-compose.free.yml)
POSTGRES_USER=ai_platform
POSTGRES_PASSWORD=ai_platform_password
POSTGRES_DB=ai_platform_dev

# Redis (from docker-compose.free.yml)
REDIS_PASSWORD=redis_dev_password

# =============================================================================
# DEVELOPMENT FEATURES
# =============================================================================

NODE_ENV=development

# Enable debug logging
DEBUG_AI_PROVIDERS=true
DEBUG_DATABASE=true
DEBUG_CACHE=true

# Local development optimizations
ENABLE_HOT_RELOAD=true
ENABLE_SOURCE_MAPS=true

# Mock data for testing (when APIs are unavailable)
USE_MOCK_AI_RESPONSES=false
USE_MOCK_DATABASE=false

# =============================================================================
# LOCAL TESTING SETTINGS
# =============================================================================

# Test database (separate from development)
TEST_DATABASE_URL=postgresql://ai_platform:ai_platform_password@localhost:5432/ai_platform_test

# Reduced rate limits for testing
RATE_LIMIT_RPM=120

# Shorter cache TTL for testing
CACHE_TTL=300

# =============================================================================
# LOCAL API ENDPOINTS
# =============================================================================

# When using local instances of services
# LOCAL_HUGGINGFACE_ENDPOINT=http://localhost:8080
# LOCAL_OLLAMA_ENDPOINT=http://localhost:11434

# =============================================================================
# DEVELOPMENT TOOLS
# =============================================================================

# Prisma Studio (database GUI)
PRISMA_STUDIO_PORT=5555

# Next.js development port
PORT=3000

# Webpack bundle analyzer
ANALYZE=false

# =============================================================================
# LOCAL FEATURE FLAGS
# =============================================================================

# Enable all features for local development
ENABLE_CACHING=true
ENABLE_DEDUPLICATION=true
ENABLE_COMPRESSION=false
ENABLE_USAGE_TRACKING=true

# Allow higher limits for local testing
MAX_CONCURRENT_REQUESTS=10

# Enable development-only features
ENABLE_DEV_TOOLBAR=true
ENABLE_QUERY_PROFILING=true